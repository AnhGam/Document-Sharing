{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=document_sharing;Username=postgres;Password=${POSTGRES_PASSWORD}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "Key": "A_Very_Secure_Secret_Key_That_Is_At_Least_32_Characters_Long",
    "Issuer": "document-sharing-manager",
    "Audience": "document-sharing-manager-users",
    "DurationInMinutes": 30
  }
}
